{
  "name": "a",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules .turbo bun.lock",
    "clean:workspaces": "turbo run clean",
    "db:push": "turbo -F @a/db push",
    "db:studio": "turbo -F @a/db studio",
    "dev": "turbo watch dev --continue",
    "dev:1": "turbo watch dev -F @a/1...",
    "postinstall": "bun lint:ws",
    "lint:ws": "sherif",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@lingual/i18n-check": "latest",
    "@types/bun": "latest",
    "depcheck": "latest",
    "sherif": "latest",
    "ts-unused-exports": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "bun@1.3.11"
}
